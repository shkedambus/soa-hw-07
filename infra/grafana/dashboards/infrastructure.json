{
  "title": "Flight Booking Infrastructure",
  "uid": "flight-booking-infra",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": {"from": "now-15m", "to": "now"},
  "panels": [
    {
      "type": "stat", "title": "PostgreSQL targets up", "id": 1,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "pg_up", "legendFormat": "{{job}}"}],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0}
    },
    {
      "type": "timeseries", "title": "Active DB connections", "id": 2,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(pg_stat_database_numbackends{datname!~\"template.*|postgres\"}) by (job)", "legendFormat": "{{job}}"}],
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0}
    },
    {
      "type": "timeseries", "title": "Committed transactions per second", "id": 3,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(pg_stat_database_xact_commit{datname!~\"template.*|postgres\"}[1m])) by (job)", "legendFormat": "{{job}}"}],
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0}
    }
  ]
}
